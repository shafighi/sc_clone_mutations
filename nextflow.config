/*
================================================================================
  sc_clone_mutations — Nextflow configuration
  Clone-aware somatic mutation analysis from scDNAseq
================================================================================
*/

manifest {
    name            = 'sc_clone_mutations'
    author          = 'TODO: your name'
    homePage        = 'https://github.com/shafighi/sc_clone_mutations'
    description     = 'Clone-aware somatic mutation analysis from single-cell DNA data'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// ─── Global defaults ────────────────────────────────────────────────────────

params {
    // ── Required inputs ─────────────────────────────────────────────────────
    bam_manifest          = null   // path to CSV: cell_id,bam_path,bai_path,sample_id,patient_id
    normal_manifest       = null   // path to CSV: sample_id,patient_id,bam_path,bai_path (optional)
    cell_metadata         = null   // path to CSV: cell_id,sample_id,patient_id,...
    medicc2_tree          = null   // path to MEDICC2 Newick tree file (*.new)
    medicc2_events        = null   // path to MEDICC2 events-per-branch TSV (optional)
    scunique_events       = null   // path to scUnique unique-events TSV

    // ── Alternative input: scUnique results directory (RDS auto-conversion) ──
    scunique_dir          = null   // path to scUnique results dir containing .RDS files
    sample_id             = null   // sample ID label (auto-detected from filenames if null)
    bam_dir               = null   // path to directory of per-cell BAMs (auto-generates manifest)

    // ── Reference genome ────────────────────────────────────────────────────
    genome                = 'hg38' // genome build label (used for logging only)
    fasta                 = null   // path to reference FASTA
    fai                   = null   // path to .fai index (auto-inferred if null)
    dict                  = null   // path to .dict (auto-inferred if null)
    germline_resource     = null   // path to gnomAD or similar VCF.gz + .tbi (Mutect2)
    germline_resource_tbi = null
    panel_of_normals      = null   // path to PoN VCF.gz + .tbi (Mutect2, optional)
    panel_of_normals_tbi  = null
    intervals             = null   // target BED file (optional; uses whole genome if null)

    // ── Clone assignment ────────────────────────────────────────────────────
    clone_strategy        = 'internal_node' // one of: internal_node | distance | event_profile | hybrid
    min_cells_per_clone   = 5
    min_branch_length     = 0.0    // minimum tree branch length to define a clone split
    distance_threshold    = null   // required when clone_strategy = 'distance'
    event_similarity_thr  = 0.5   // Jaccard threshold for event_profile / hybrid strategies
    max_clones            = null   // cap on number of clones (null = no cap)
    small_clone_action    = 'merge' // one of: drop | merge | flag
    clone_assignment_conf = 0.0   // minimum assignment confidence score (0.0 = keep all)

    // ── Cell QC filters (applied before pseudobulking) ──────────────────────
    min_mapped_reads      = 100000  // minimum mapped reads per cell
    max_duplication_rate  = 0.95   // max fraction of duplicate reads
    min_clone_confidence  = 0.0    // minimum clone assignment confidence score

    // ── Pseudobulk options ───────────────────────────────────────────────────
    mark_duplicates       = true
    all_tumor_pseudobulk  = false  // also generate one merged BAM across all clones

    // ── Mutation callers ─────────────────────────────────────────────────────
    callers               = ['mutect2', 'strelka2', 'freebayes'] // subset or all
    tumor_only            = false  // set true when no matched normal is provided
    // Mutect2 extra args
    mutect2_extra_args    = '--af-of-alleles-not-in-resource 0.0000025'
    // Strelka2 extra args
    strelka2_extra_args   = ''
    // FreeBayes extra args
    freebayes_extra_args  = '--min-alternate-fraction 0.05 --min-alternate-count 3 --pooled-continuous'

    // ── Consensus calling ────────────────────────────────────────────────────
    consensus_min_callers = 2      // variant must be supported by this many callers
    consensus_pass_only   = true   // only use PASS variants in consensus

    // ── Optional annotation ──────────────────────────────────────────────────
    annotate              = false  // run VEP annotation (requires VEP cache)
    vep_cache             = null   // path to VEP offline cache directory
    vep_species           = 'homo_sapiens'
    vep_genome_build      = 'GRCh38'

    // ── Output / reporting ───────────────────────────────────────────────────
    outdir                = 'results'
    publish_dir_mode      = 'copy'
    multiqc_config        = "${projectDir}/assets/multiqc_config.yml"
    email                 = null   // send completion email (requires mail server)

    // ── Pipeline meta ────────────────────────────────────────────────────────
    help                  = false
    version               = false
    validate_params       = true
    monochrome_logs       = false

    // ── Demo / test mode ─────────────────────────────────────────────────────
    test_mode             = false  // use tiny synthetic inputs in tests/
}

// ─── Profile definitions (docker / singularity / slurm / local) ─────────────

profiles {
    // ── Local execution with Docker ─────────────────────────────────────────
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false
    }

    // ── Cluster execution with Singularity/Apptainer ─────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--bind /mnt/nas-data:/mnt/nas-data'
        docker.enabled         = false
        conda.enabled          = false
    }

    // ── SLURM cluster (combine with singularity) ─────────────────────────────
    slurm {
        process.executor       = 'slurm'
        includeConfig 'conf/slurm.config'
    }

    // ── Test / smoke-test profile ────────────────────────────────────────────
    test {
        includeConfig 'conf/test.config'
    }

    // ── Local debug (no container) — requires manual tool installation ────────
    local {
        docker.enabled         = false
        singularity.enabled    = false
        process.executor       = 'local'
    }
}

// ─── Include modular configs ─────────────────────────────────────────────────

includeConfig 'conf/base.config'
includeConfig 'conf/resources.config'

// ─── Global process defaults ─────────────────────────────────────────────────

process {
    shell          = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy  = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries     = 2
    maxErrors      = '-1'
}

// ─── Execution reports ───────────────────────────────────────────────────────

timeline {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
}
report {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
}
dag {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
}

// ─── Capture tool versions ───────────────────────────────────────────────────

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline.file = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html"
report.file   = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html"
trace.file    = "${params.outdir}/pipeline_info/trace_${trace_timestamp}.txt"
