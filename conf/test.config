/*
================================================================================
  test.config — minimal smoke-test parameters
  Uses synthetic tiny inputs in tests/fixtures/
  Run with: nextflow run main.nf -profile test,docker
================================================================================
*/

params {
    test_mode = true

    // Inputs point to tiny synthetic files in tests/fixtures/
    bam_manifest    = "${projectDir}/tests/fixtures/bam_manifest.csv"
    cell_metadata   = "${projectDir}/tests/fixtures/cell_metadata.csv"
    medicc2_tree    = "${projectDir}/tests/fixtures/test_tree.new"
    medicc2_events  = "${projectDir}/tests/fixtures/test_tree_events.tsv"
    scunique_events = "${projectDir}/tests/fixtures/scunique_events.tsv"

    // Reference: use bundled tiny FASTA (chr21 slice)
    fasta           = "${projectDir}/tests/fixtures/ref/chr21_slice.fa"
    fai             = "${projectDir}/tests/fixtures/ref/chr21_slice.fa.fai"
    dict            = "${projectDir}/tests/fixtures/ref/chr21_slice.dict"

    // No germline resources in test mode — tumor-only calling
    tumor_only      = true
    callers         = ['mutect2', 'strelka2']  // freebayes optional in test

    // Relaxed clone criteria for tiny test dataset
    min_cells_per_clone = 2
    clone_strategy      = 'internal_node'

    outdir = 'test_results'

    // Cap resources for local test run
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '1.h'
}
