/*
================================================================================
  slurm.config — SLURM executor options
  Activate with: -profile singularity,slurm
================================================================================
*/

params {
    // Override cluster-wide caps to match your HPC partition limits
    max_cpus   = 32
    max_memory = '256.GB'
    max_time   = '240.h'
}

process {
    executor       = 'slurm'
    // TODO: set your default SLURM partition/queue
    queue          = 'compute'
    clusterOptions = '--export=ALL'

    // Per-label SLURM queue overrides (optional)
    withLabel: process_high {
        queue = 'highmem'    // TODO: rename to your high-memory partition
    }
    withLabel: process_long {
        queue = 'long'       // TODO: rename to your long-runtime partition
    }
}

// Nextflow executor settings
executor {
    $slurm {
        queueSize       = 200   // max concurrent SLURM jobs
        pollInterval    = '30s'
        submitRateLimit = '10 sec'
    }
}
