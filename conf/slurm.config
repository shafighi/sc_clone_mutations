/*
================================================================================
  slurm.config — SLURM executor options
  Activate with: -profile singularity,slurm
================================================================================
*/

params {
    // Override cluster-wide caps to match your HPC partition limits
    max_cpus   = 32
    max_memory = '256.GB'
    max_time   = '240.h'
}

process {
    executor       = 'slurm'
    queue          = 'epyc'
    clusterOptions = '--export=ALL'
}

// Nextflow executor settings
executor {
    $slurm {
        queueSize       = 200   // max concurrent SLURM jobs
        pollInterval    = '30s'
        submitRateLimit = '10 sec'
    }
}
